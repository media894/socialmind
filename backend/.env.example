# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=socialmind
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AWS S3 (optional — leave blank to use local storage in dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=socialmind-media
AWS_S3_REGION_NAME=us-east-1

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# Email OTP delivery
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=SocialMind <your-gmail-address@gmail.com>

# Google / YouTube OAuth
# Used by the Google sign-in popup on /login and the YouTube connect flow in Settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Exact backend origin used for Google OAuth callbacks.
# Example for local dev: http://localhost:8000
GOOGLE_OAUTH_REDIRECT_BASE=http://localhost:8000

# Frontend origin used when the OAuth callback posts tokens back to the popup opener.
PUBLIC_APP_URL=http://localhost:3000

# PayPal subscriptions
# Use "sandbox" for testing and "live" for production.
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PRO_PLAN_ID=
PAYPAL_ENTERPRISE_PLAN_ID=
